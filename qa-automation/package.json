{
  "name": "parts-inventory-qa-automation",
  "version": "1.0.0",
  "description": "Playwright test automation + agent runner for parts-inventory login/RBAC feature (staging)",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "setup:data": "node scripts/setup-test-data.mjs",
    "teardown:data": "node scripts/teardown-test-data.mjs",
    "agent:run": "node agent/run-and-report.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5"
  }
}
