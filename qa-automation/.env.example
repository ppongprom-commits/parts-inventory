# ------------------------------------------------------------
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริงของ staging
# ห้าม commit .env ตัวจริงเข้า git เด็ดขาด (ใส่ .env ใน .gitignore แล้ว)
# ------------------------------------------------------------

# URL ของ staging deployment จริงบน Vercel
STAGING_BASE_URL=https://parts-inventory-staging.vercel.app

# Supabase staging project (สำหรับ setup/teardown test data ผ่าน Admin API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx   # service_role key ของ staging เท่านั้น ห้ามใช้ของ production
# ใช้สำหรับเทสต์ RLS/role โดยตรง (TC-206, TC-207) — เป็น key เดียวกับที่ app จริงใช้ฝั่ง client
# (lib/supabaseClient.js อ่านจาก NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY) หาได้จาก Supabase
# Dashboard > Settings > API Keys > Publishable key (หรือ anon key ถ้ายังเป็นระบบเก่า)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# ------------------------------------------------------------
# Test credentials ตาม Test Data Matrix (ควรตรงกับที่ setup-test-data.mjs สร้างไว้)
# ------------------------------------------------------------
TEST_OWNER_EMAIL=qa_owner@testshop.com
TEST_OWNER_PASSWORD=Owner@1234

TEST_MANAGER_EMAIL=qa_manager@testshop.com
TEST_MANAGER_PASSWORD=Mgr@1234

TEST_SUPERVISOR_USERNAME=qa_sup01
TEST_SUPERVISOR_PIN=4821

TEST_TECHNICIAN_USERNAME=qa_tech01
TEST_TECHNICIAN_PIN=5567

TEST_ASSISTANT_USERNAME=qa_asst01
TEST_ASSISTANT_PIN=1123

TEST_OWNER_PLATFORMADMIN_EMAIL=qa_owner_platformadmin@testshop.com
TEST_OWNER_PLATFORMADMIN_PASSWORD=Pwd@1234

TEST_DISABLED_OWNER_EMAIL=qa_disabled_owner@testshop.com
TEST_DISABLED_OWNER_PASSWORD=Pwd@1234

TEST_NEWUSER_EMAIL=qa_newuser@testshop.com
TEST_NEWUSER_PASSWORD=Pwd@1234

# ------------------------------------------------------------
# TC-302: บัญชีแยกสำหรับเทสต์ concurrent-session limit
# (shop เฉพาะสำหรับกลุ่มนี้ ตั้ง plan='trial' -> maxConcurrentSessions=3, maxMembers=3
#  ใน config/subscriptionTiers.js — ต้องแยกจาก shop หลักที่ตั้งเป็น enterprise/unlimited)
# ------------------------------------------------------------
TEST_CONCURRENT1_EMAIL=qa_concurrent1@testshop.com
TEST_CONCURRENT1_PASSWORD=Conc@1234
TEST_CONCURRENT2_EMAIL=qa_concurrent2@testshop.com
TEST_CONCURRENT2_PASSWORD=Conc@1234
TEST_CONCURRENT3_EMAIL=qa_concurrent3@testshop.com
TEST_CONCURRENT3_PASSWORD=Conc@1234
TEST_CONCURRENT4_EMAIL=qa_concurrent4@testshop.com
TEST_CONCURRENT4_PASSWORD=Conc@1234

# ------------------------------------------------------------
# คืนวันที่ 21 ก.ค. 2026 — บัญชีเพิ่มสำหรับฟีเจอร์ใหม่คืนนั้น
# ------------------------------------------------------------

# การ์ด "Field Scanner Role" — บัญชี username+PIN เหมือน supervisor/technician/assistant
# ด้านบน แต่ role=field_scanner (กรอก/แก้ไขอะไหล่ได้ ขายไม่ได้ ไม่เห็นข้อมูลลูกค้า)
TEST_FIELDSCANNER_USERNAME=qa_fieldscan01
TEST_FIELDSCANNER_PIN=8842

# บัญชี field_scanner อีกตัวที่ setup-test-data.mjs ตั้ง expires_at เป็นอดีตไปแล้วเสมอ (ไม่ว่าจะรัน
# วันไหนก็ตาม — คำนวณสดจาก "เมื่อวาน" ตอน setup ไม่ใช่ค่า fix ตายตัวใน .env) ใช้ทดสอบว่า login ไม่ผ่าน
# พร้อมข้อความ "บัญชีชั่วคราวนี้หมดอายุแล้ว" (components/RequireAuth.js data-testid=expired-account-screen)
TEST_FIELDSCANNER_EXPIRED_USERNAME=qa_fieldscan_expired
TEST_FIELDSCANNER_EXPIRED_PIN=9911
