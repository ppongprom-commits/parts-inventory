From 49e6d13b4f8def0b620e508c8096472078e6a55f Mon Sep 17 00:00:00 2001
From: "Claude (sandbox patch)" <claude@anthropic.local>
Date: Mon, 20 Jul 2026 08:24:08 +0000
Subject: [PATCH] Fix: filter/cleanup stale user_sessions rows before counting
 concurrent sessions
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Root cause of 'login แล้วเด้งออกใน 1 วิ' บนอู่บีม การาจ (shop_id=3, tier founder):
user_sessions มีแถวค้าง 8 distinct user จากหลายวันก่อน (releaseSession พึ่ง
beforeunload ซึ่งไม่ fire เสมอบนมือถือ/force-quit/เน็ตหลุด) ทำให้ concurrent
session count ชนแคป 8/8 ทั้งที่ไม่มีใครใช้งานจริง

- เพิ่ม sessionStaleAfterMinutes=3 ใน GLOBAL_SESSION_CONFIG
- registerSession() ลบแถวที่ last_seen_at เก่ากว่า threshold ก่อนนับทุกครั้ง
  (ทั้งจำนวนเครื่องของ user เองและจำนวน distinct user ต่ออู่)

หมายเหตุ: sessionError ใน AuthProvider ยัง set ไว้เฉยๆ ไม่มี UI render — เป็นอีก
issue แยกที่ต้องแก้เพิ่ม (ยังไม่ได้แก้ในคอมมิตนี้)
---
 config/subscriptionTiers.js |  4 ++++
 lib/sessionTracking.js      | 14 +++++++++++++-
 2 files changed, 17 insertions(+), 1 deletion(-)

diff --git a/config/subscriptionTiers.js b/config/subscriptionTiers.js
index 9a03b36..adae483 100644
--- a/config/subscriptionTiers.js
+++ b/config/subscriptionTiers.js
@@ -15,6 +15,10 @@ export const GLOBAL_SESSION_CONFIG = {
   maxDevicesPerUser: 2,
   idleTimeoutMinutes: 15,        // ไม่มีกิจกรรมเกินเท่านี้ -> เริ่มนับถอยหลัง
   idleWarningCountdownSeconds: 100, // เวลานับถอยหลังก่อน logout อัตโนมัติ
+  sessionStaleAfterMinutes: 3, // แถวใน user_sessions ที่ last_seen_at เก่ากว่านี้ถือว่าเป็น
+                                // "session ผี" (ปิดแท็บ/แอปมือถือ/เน็ตหลุดโดยไม่ผ่าน beforeunload)
+                                // ไม่นับใน concurrent session limit และถูกเก็บกวาดทิ้งอัตโนมัติ
+                                // (heartbeat ทุก 60 วิ ค่านี้เผื่อพลาดได้ ~2-3 รอบก่อนถือว่าหลุดจริง)
 };
 
 export const SUBSCRIPTION_TIERS = {
diff --git a/lib/sessionTracking.js b/lib/sessionTracking.js
index 5dc7a3f..483c125 100644
--- a/lib/sessionTracking.js
+++ b/lib/sessionTracking.js
@@ -8,7 +8,18 @@ import { GLOBAL_SESSION_CONFIG, getTierConfig } from "../config/subscriptionTier
 export async function registerSession(userId, shopId, subscriptionPlan) {
   const tier = getTierConfig(subscriptionPlan);
 
-  // 1) เช็คจำนวนเครื่องที่ user คนนี้ login อยู่ (ทุก shop รวมกัน)
+  // 0) เก็บกวาด session ที่ "ตายจริง" ทิ้งก่อนนับอะไรทั้งสิ้น
+  // เหตุผล: releaseSession() พึ่งพา event beforeunload ซึ่งไม่ fire เสมอ (ปิดแอปเบราว์เซอร์บนมือถือ,
+  // เน็ตหลุด, force-quit, บางเบราว์เซอร์ตอนปิดแท็บ) แถวที่ค้างแบบนี้จะไปกิน slot ของ
+  // concurrent session limit อย่างผิด ๆ ทั้งที่ไม่มีใครใช้งานจริงแล้ว จึงต้องเคลียร์ด้วย
+  // last_seen_at staleness ทุกครั้งก่อนนับ (แทนที่จะพึ่ง release ฝั่ง client อย่างเดียว)
+  const staleBeforeIso = new Date(
+    Date.now() - GLOBAL_SESSION_CONFIG.sessionStaleAfterMinutes * 60 * 1000
+  ).toISOString();
+  await supabase.from("user_sessions").delete().lt("last_seen_at", staleBeforeIso);
+
+  // 1) เช็คจำนวนเครื่องที่ user คนนี้ login อยู่ (ทุก shop รวมกัน) — แถวที่เหลือหลังขั้นตอน 0
+  //    คือ session ที่ยัง active จริงเท่านั้น
   const { data: myDeviceSessions } = await supabase
     .from("user_sessions")
     .select("session_id, last_seen_at")
@@ -28,6 +39,7 @@ export async function registerSession(userId, shopId, subscriptionPlan) {
   }
 
   // 2) เช็คจำนวนคน (distinct user) ที่ login พร้อมกันทั้งอู่ (ไม่นับ user นี้ที่กำลังจะเข้าเอง)
+  //    หลังขั้นตอน 0 แล้ว แถวที่เหลือคือ session ที่ยัง active จริงเท่านั้น ไม่ใช่ session ผี
   if (tier.maxConcurrentSessions !== null && tier.maxConcurrentSessions !== undefined) {
     const { data: shopSessions } = await supabase
       .from("user_sessions")
-- 
