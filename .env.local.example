# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Supabase Dashboard
# Project Settings -> Data API (สำหรับ URL) และ API Keys (สำหรับ publishable key)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⚠️ Service Role Key — ใช้เฉพาะฝั่ง server (app/api/**) เท่านั้น
# ห้ามเติม NEXT_PUBLIC_ ข้างหน้าเด็ดขาด ไม่งั้นจะหลุดไปฝั่ง browser
# หาได้ที่ Supabase Dashboard -> Project Settings -> API Keys -> Secret keys (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
